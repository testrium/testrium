# ─── Testrium Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values before running docker-compose

# ─── App Port ─────────────────────────────────────────────────────────────────
APP_PORT=80

# ─── MySQL Database ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=testrium
MYSQL_USER=testrium
MYSQL_PASSWORD=changeme_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random string (min 32 chars)
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING_HERE

# ─── JIRA Encryption Key ──────────────────────────────────────────────────────
# Must be EXACTLY 16 characters (AES-128)
JIRA_ENCRYPTION_KEY=TestriumJiraKey1

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Use http://localhost for local Docker, or your public domain in production
CORS_ALLOWED_ORIGINS=http://localhost

# ─── Admin Account ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@testrium.com
ADMIN_PASSWORD=Admin@123

# ─── Client Branding ──────────────────────────────────────────────────────────
CLIENT_NAME=Testrium

# ─── Registration ─────────────────────────────────────────────────────────────
REGISTRATION_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
